# ============================================
# VALORANT Custom Team Builder — 環境変数設定
# ============================================
#
# すべての環境変数はオプションです。
# 未設定の場合、アプリケーションはデモモードで動作します。
# （インメモリデータストア + ランダムランク生成）
#
# 使い方:
#   1. このファイルを `.env.local` にコピーしてください
#      cp .env.example .env.local
#   2. 必要な値を設定してください
#

# --------------------------------------------
# AWS DynamoDB 設定
# --------------------------------------------
# AWS リージョン（例: ap-northeast-1）
# ※ Amplify では AWS_ プレフィックスが予約のため APP_AWS_REGION を使用
APP_AWS_REGION=

# DynamoDB ルームテーブル名
DYNAMODB_ROOMS_TABLE_NAME=

# DynamoDB プレイヤーテーブル名
DYNAMODB_PLAYERS_TABLE_NAME=

# --------------------------------------------
# AWS AppSync 設定（リアルタイム同期）
# --------------------------------------------
# NEXT_PUBLIC_ プレフィックスによりクライアントサイドからもアクセス可能

# AppSync GraphQL API エンドポイント URL
NEXT_PUBLIC_APPSYNC_API_URL=

# AppSync API キー
NEXT_PUBLIC_APPSYNC_API_KEY=

# --------------------------------------------
# Valorant API 設定（サーバーサイド専用）
# --------------------------------------------
# Henrik-3 Unofficial Valorant API キー
# ※ サーバーサイドでのみ使用され、クライアントには公開されません
VALORANT_API_KEY=HDEV-1470bdba-e6b2-4925-ba52-6f85539517e5
