# VALORANT Custom Team Builder
#
# 未設定の場合はインメモリのデモストアで動きます。
# Supabase を使う場合は、以下を `.env.local` または Vercel の Environment Variables に設定してください。

# --------------------------------------------
# Supabase
# --------------------------------------------
# Server-side API routes use the service role key.
# 絶対に NEXT_PUBLIC_ を付けないでください。
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Browser-side Realtime uses the publishable key.
# 旧プロジェクトでは anon key を NEXT_PUBLIC_SUPABASE_ANON_KEY に入れても動きます。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --------------------------------------------
# Valorant API
# --------------------------------------------
# サーバー側のみで使用します。ブラウザへ公開しないでください。
VALORANT_API_KEY=
